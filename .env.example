# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost
GUI_PORT=3000
SHUTDOWN_TIMEOUT=5

# Application Configuration
MAX_ELEMENTS=12
MEMORY_STATS_FREQ=1000
QUIET=false
ENABLE_CORS=true
ENABLE_METRICS=false

# Database Configuration (optional)
# Supported drivers: postgres, mysql, sqlite3
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=permutation_db
DB_TABLE=elements
DB_COLUMN=value
DB_SSL_MODE=disable

# Configuration File Path (optional)
# If specified, settings will be loaded from this file
# Environment variables will override file settings
CONFIG_FILE=
