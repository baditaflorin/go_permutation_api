# =============================================================================
# Go Permutation API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values marked with <CHANGE_ME>
# NEVER commit .env to version control.
#
# Required before first run:
#   cp .env.example .env
#   # Edit .env with your actual values
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=127.0.0.1   # use 0.0.0.0 only behind a reverse proxy
GUI_PORT=3000
SHUTDOWN_TIMEOUT=5

# ── Application ───────────────────────────────────────────────────────────────
MAX_ELEMENTS=12
MEMORY_STATS_FREQ=1000
QUIET=false
ENABLE_CORS=false        # set to true if serving a browser frontend from another origin
ENABLE_METRICS=false     # /metrics JSON endpoint
ENABLE_PROMETHEUS=false  # /metrics Prometheus text format (overrides ENABLE_METRICS)
ENABLE_PPROF=false       # /debug/pprof/* — NEVER enable in production

# ── Logging (ADR-0006) ────────────────────────────────────────────────────────
LOG_LEVEL=info           # debug | info | warn | error
LOG_FORMAT=json          # json | text

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100  # requests allowed per window
RATE_LIMIT_WINDOW=60     # window in seconds

# ── Trusted Proxies (ADR-0003) ────────────────────────────────────────────────
# Comma-separated CIDRs. X-Forwarded-For trusted only from these.
# Leave empty to use RemoteAddr directly.
TRUSTED_PROXIES=

# ── Database (optional) ───────────────────────────────────────────────────────
# Supported drivers: postgres, mysql, sqlite3
# Leave DB_DRIVER empty to disable database integration.
DB_DRIVER=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=<CHANGE_ME>
DB_PASSWORD=<CHANGE_ME>   # use a strong random password; minimum 20 characters recommended
DB_DATABASE=permutation_db
DB_TABLE=elements
DB_COLUMN=value
DB_SSL_MODE=require        # NEVER use 'disable' in production

# ── Configuration File (optional) ─────────────────────────────────────────────
# If set, loads config from this JSON file before applying env vars.
# Env vars always take precedence.
CONFIG_FILE=
